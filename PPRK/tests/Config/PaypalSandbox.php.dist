    public const CLIENT_SECRET = 'YOUR_SANDBOX_CLIENT_SECRET';

    public const SANDBOX_URL = 'https://api-m.sandbox.paypal.com';
    public const LIVE_URL = 'https://api-m.paypal.com';

    public const RETURN_URL = 'https://your-test-app.example.com/paypal/return';
    public const CANCEL_URL = 'https://your-test-app.example.com/paypal/cancel';

    public const CURRENCY = 'USD';
    public const AMOUNT = 10.00;
}
